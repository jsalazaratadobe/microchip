          "selector": ".simpletable",
          "style": null,
          "blocks": ["table-compare"],
          "defaultContent": []
        },
        {
          "id": "sec-hw-sw-solutions",
          "name": "Motor Control Hardware and Software Solutions",
          "selector": ".cardcarousel",
          "style": null,
          "blocks": ["carousel-solutions"],
          "defaultContent": []
        },
        {
          "id": "sec-products",
          "name": "Products (Parametric)",
          "selector": ".tabs.panelcontainer",
          "style": null,
          "blocks": ["tabs-parametric"],
          "defaultContent": []
        }
      ]
    }
  ]
